{
  "name": "@ecca/contracts",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node",
    "deploy:local": "hardhat run --network cortex scripts/deploy.ts",
    "build": "hardhat compile && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf artifacts cache typechain-types dist"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-viem": "^3.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "hardhat": "^2.22.7",
    "typescript": "^5.5.4",
    "rimraf": "^6.0.1",
    "viem": "^2.21.1"
  },
  "dependencies": {
    "@ecca/chain": "workspace:*",
    "@ecca/proto": "workspace:*"
  }
}
