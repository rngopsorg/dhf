    "@ecca/db": "workspace:*",
    "@ecca/chain": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "tsx": "^4.16.2",
    "rimraf": "^6.0.1",
    "@types/node": "^20.14.10"
  }
