# --- Chain endpoints ---
CORTEX_RPC=http://cortex-evm:8545
CORTEX_WS=ws://cortex-evm:8546
CORTEX_CHAIN_ID=131072
MEDULLA_RPC=http://medulla-pow:8332
HIPPOCAMPUS_API=http://hippocampus-dag:5001
HIPPOCAMPUS_GATEWAY=http://hippocampus-dag:8080

# --- Cognitive parameters ---
ECCA_MASTER_SECRET=ecca-genesis-quellcrist-falconer-2026
ECCA_DRIFT_MAX=15
ECCA_FIDELITY_MIN=0.6
ECCA_EPOCH_INTERVAL_MS=4000
ECCA_DIFFICULTY=4
ECCA_DEFAULT_BANDWIDTH=1000
