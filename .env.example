# --- Postgres (cortical-registry-db) ---
POSTGRES_USER=ecca
POSTGRES_PASSWORD=quellcrist
POSTGRES_DB=ecca_registry
POSTGRES_HOST=cortical-registry-db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ecca:quellcrist@cortical-registry-db:5432/ecca_registry

# --- Redis (working-memory-cache) ---
REDIS_HOST=working-memory-cache
REDIS_PORT=6379
REDIS_URL=redis://working-memory-cache:6379

# --- NATS (axonal-bus) ---
NATS_URL=nats://axonal-bus:4222

# --- MinIO (shard-vault) ---
MINIO_ENDPOINT=shard-vault
MINIO_PORT=9000
MINIO_ACCESS_KEY=ecca-access
MINIO_SECRET_KEY=ecca-secret-quellcrist
